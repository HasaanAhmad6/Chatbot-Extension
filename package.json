{
  "name": "rag-site-explorer-extension",
  "version": "0.5.0",
  "description": "Chrome extension to index public website pages and chat with them locally.",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "rag",
    "chatbot",
    "openai",
    "gemini",
    "llm",
    "embedding"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node ./scripts/copy-assets.cjs",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.269",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.54"
  }
}
