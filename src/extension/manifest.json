{
  "manifest_version": 3,
  "name": "Rag Site Explorer",
  "version": "0.4.0",
  "description": "Index website pages and chat with the whole domain locally using your own AI provider keys.",
  "permissions": [
    "sidePanel",
    "storage",
    "offscreen",
    "unlimitedStorage",
    "activeTab"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Rag Site Explorer"
  }
}
